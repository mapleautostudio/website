# Resend — get key at https://resend.com/api-keys
# Until a real domain is verified, Resend's free tier only lets you send
# to the email tied to the Resend account.
RESEND_API_KEY=

# Where booking notification emails go. While testing, use the Gmail tied
# to your Resend account.
BOOKING_NOTIFY_TO=khushdeep899@gmail.com

# Sender address. Use onboarding@resend.dev until mapleautostudio.ca is
# verified in Resend, then switch to bookings@mapleautostudio.ca.
BOOKING_NOTIFY_FROM="Maple Auto Studio <onboarding@resend.dev>"

# Supabase — Project Settings → API
# The service role key bypasses RLS. Server-only. Never expose to client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon key is needed for the auth flow on the admin login.
SUPABASE_ANON_KEY=

# Admin allowlist — comma-separated emails permitted to sign in to /admin.
# The Supabase user must already exist (Authentication → Users → Add user).
ADMIN_EMAILS=khushdeep899@gmail.com
